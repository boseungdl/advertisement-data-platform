# 광고 캠페인 분석 플랫폼 — 환경 변수 샘플
#
# 실제 사용 시:
#   cp final/infra/.env.example final/infra/.env
#   값 채우고 → docker compose가 자동 로드
# .env 파일은 .gitignore에 등록되어 있음 (커밋 X).

# ──────────────────────────────────────────────────────────────
# AWS — Iceberg/Glue/Athena/QuickSight 사용 (S1.4에서 실제 셋업)
# ──────────────────────────────────────────────────────────────
AWS_PROFILE=iceberg-lab
AWS_REGION=ap-northeast-2
AWS_DEFAULT_REGION=ap-northeast-2

# ──────────────────────────────────────────────────────────────
# Kafka — Bronze 단계 (로컬 도커)
# ──────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=kafka:29092       # 컨테이너 내부에서 사용
# KAFKA_BOOTSTRAP_HOST=localhost:9092  # 호스트 producer가 사용 (kafka_producer.py)
KAFKA_TOPIC=ad-events

# ──────────────────────────────────────────────────────────────
# Iceberg / S3 — Silver/Gold 단계 (AWS, S1.4에서 실제 값 채움)
# ──────────────────────────────────────────────────────────────
S3_BUCKET=meta-ads-lakehouse-CHANGE_ME   # 본인 버킷 이름으로 교체
S3_PREFIX=lakehouse/ads
ICEBERG_DB=iceberg_ads_db
